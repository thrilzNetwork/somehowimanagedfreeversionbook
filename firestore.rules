rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.email == "thrilznetwork@gmail.com" && 
             request.auth.token.email_verified == true;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasTier(minTier) {
      let userTier = getUserData().tier;
      return minTier == "basic" || 
             (minTier == "premium" && (userTier == "premium" || userTier == "elite")) ||
             (minTier == "elite" && userTier == "elite");
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Legacy Entries
    match /entries/{entryId} {
      allow create: if true; // Basic validation handled in app
      allow read: if isAdmin();
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (
        (request.auth.uid == userId && request.resource.data.tier == resource.data.tier) || 
        isAdmin()
      );
    }

    // Community Content
    match /content/{contentId} {
      allow read: if isAdmin() || (isAuthenticated() && hasTier(resource.data.minTier));
      allow write: if isAdmin();
    }

    // Consultations
    match /consultations/{consultationId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userUid == request.auth.uid);
      allow update: if isAdmin();
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
