rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (Firebase Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - name: string (required)
    //   - email: string (required)
    //   - photoURL: string (optional)
    //   - tier: string (required, enum: basic, premium, elite)
    //   - joinedAt: timestamp (required)
    //   - referralCode: string (required)
    //   - points: number (required)
    //   - referredBy: string (optional)
    //
    // Collection: content
    // Document ID: {contentId}
    // Fields:
    //   - title: string (required)
    //   - body: string (required)
    //   - type: string (required, enum: drop, price, update, pdf)
    //   - minTier: string (required, enum: basic, premium, elite)
    //   - url: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: consultations
    // Document ID: {consultationId}
    // Fields:
    //   - userUid: string (required)
    //   - userName: string (required)
    //   - userEmail: string (required)
    //   - message: string (required)
    //   - status: string (required, enum: pending, contacted, completed)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "thrilznetwork@gmail.com" && request.auth.token.email_verified == true);
    }

    function hasTier(minTier) {
      let userTier = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tier;
      return minTier == "basic" || 
             (minTier == "premium" && (userTier == "premium" || userTier == "elite")) ||
             (minTier == "elite" && userTier == "elite");
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'tier', 'joinedAt', 'referralCode', 'points']) &&
             data.uid is string &&
             data.name is string &&
             data.email is string &&
             data.tier in ['basic', 'premium', 'elite'] &&
             data.referralCode is string &&
             data.points is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // User Profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isAuthenticated() && (
        (isOwner(userId) && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['careerProfile']) ||
          (request.resource.data.tier == resource.data.tier && request.resource.data.points == resource.data.points)
        )) || 
        isAdmin()
      );
    }

    // Community Content
    match /content/{contentId} {
      allow read: if isAdmin() || (isAuthenticated() && 
                    exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                    hasTier(resource.data.minTier));
      allow write: if isAdmin();
    }

    // Consultations
    match /consultations/{consultationId} {
      allow create: if isAuthenticated() && request.resource.data.userUid == request.auth.uid;
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userUid == request.auth.uid);
      allow update: if isAdmin();
    }

    // Legacy Entries
    match /entries/{entryId} {
      allow create: if true;
      allow read: if isAdmin();
    }

    // Chapter Visuals
    match /chapter_visuals/{visualId} {
      allow read: if true;
      allow write: if request.resource.data.imageUrl is string && request.resource.data.imageUrl.size() < 1000000 &&
                      request.resource.data.prompt is string && request.resource.data.prompt.size() < 2000;
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
